{
  "name": "sci-ai-studio",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -k -n server,web \"npm run dev -w @studio/server\" \"npm run dev -w @studio/web\"",
    "build": "npm run build --workspaces --if-present",
    "check": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
