AI_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DATABASE_PATH=../../data/studio
PORT=3011
PUBLIC_API_URL=http://127.0.0.1:3011
ALLOWED_ORIGINS=http://127.0.0.1:5178

# Production metadata database. Leave empty in local development.
DATABASE_URL=

# Qwen / DashScope OCR and summaries.
DASHSCOPE_API_KEY=
DASHSCOPE_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
QWEN_VISION_MODEL=qwen3.6-plus
# Optional fallback matching the current Case Hub Qwen setup.
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_QWEN_MODEL=qwen/qwen2.5-vl-72b-instruct
SOURCE_WORKER_CONCURRENCY=2
PDF_OCR_MAX_PAGES=12

# Alibaba Cloud OSS. When absent, local development storage is used.
OSS_REGION=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
SOURCE_STORAGE_PATH=../../data/studio/objects
