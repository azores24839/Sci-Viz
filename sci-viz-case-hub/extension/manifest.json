{
  "manifest_version": 3,
  "name": "科研视觉案例采集器",
  "version": "1.0.0",
  "description": "一键保存科研视觉案例到本地案例库",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting",
    "downloads",
    "notifications"
  ],
  "host_permissions": [
    "http://localhost:3001/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "科研视觉案例库"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
